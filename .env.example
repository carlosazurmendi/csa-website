# ============================================================================
# CSA — environment template. Copy to `.env` and fill real values.
# Secrets are set in the real environment by the operator — never commit `.env`.
# Only NEXT_PUBLIC_* values are exposed to the browser.
# ============================================================================

# ---- Payload core ----
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32

# ---- Database: EXISTING self-hosted Supabase Postgres ----
# The app + migrator join the Supabase stack's docker network (SUPABASE_NETWORK below),
# so the host is the Postgres CONTAINER name `db` (fallback `supabase-db`), port 5432.
# Use the DIRECT connection on 5432, NOT the 6543 transaction pooler (Payload runs DDL +
# prepared statements the transaction pooler breaks). PASSWORD = POSTGRES_PASSWORD from
# the Supabase stack's own .env (not shown in Studio).
DATABASE_URI=postgres://postgres:PASSWORD@db:5432/postgres
# The docker network the self-hosted Supabase stack runs on (must already exist).
SUPABASE_NETWORK=supabase_default
# TLS to self-hosted Supabase:
#   true  (default) -> SSL on; rejectUnauthorized defaults to false (self-signed cert ok)
#   false           -> no SSL (only on a trusted private network / local dev DB)
DATABASE_SSL=true
# Set true once a proper CA chain is trusted by the host.
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ---- Supabase end-user Auth (self-hosted) ----
NEXT_PUBLIC_SUPABASE_URL=https://supabase.your-domain.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...ANON_KEY
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE_KEY
# Optional SERVER-ONLY override for the hostname the app uses to reach Supabase Auth
# from inside the network (server components / middleware). Defaults to
# NEXT_PUBLIC_SUPABASE_URL when unset; set it only if the server should reach
# Supabase over a private/internal address instead of the public URL.
SUPABASE_INTERNAL_URL=
# Optional: set to "true" to show the "Continue with Google" button on login/signup
# (requires Google OAuth configured in Supabase Auth). Empty/false hides it.
NEXT_PUBLIC_AUTH_GOOGLE=

# ---- Media storage: Supabase Storage (S3-compatible) — REQUIRED (no local-disk fallback) ----
# Create TWO buckets in Supabase Storage, then generate S3 access keys
# (Supabase Studio -> Storage -> Settings -> S3 access keys):
#   • S3_PUBLIC_BUCKET    — PUBLIC (anonymous read): marketing imagery, thumbnails.
#   • S3_PROTECTED_BUCKET — PRIVATE (no public read): purchased template deliverables
#     and uploaded lesson videos. Served only via short-lived presigned URLs after an
#     entitlement / enrollment check (src/lib/protectedMedia.ts) — never link directly.
# Set ALL FOUR S3 connection vars (endpoint, access key id, secret, region) together;
# production refuses to boot without them, and a partial set is rejected at startup.
SUPABASE_S3_ENDPOINT=https://supabase.your-domain.com/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=marketing
S3_PROTECTED_BUCKET=course-assets

# ---- Redis (internal compose hostname `redis`, not published) ----
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://default:change-me-strong-redis-password@redis:6379

# ---- Public URLs ----
# Canonical public origin. REQUIRED in production: it is the trusted base for the
# Stripe Checkout success/cancel redirect and the Supabase auth callback. If unset,
# checkout fails closed (it will NOT fall back to the inbound Host header).
NEXT_PUBLIC_SERVER_URL=https://app.example.com
# Optional extra trusted origins (comma-separated) honoured for the checkout/auth
# redirect when the request arrives on one of them — e.g. an apex + www, or staging.
# Leave empty to trust only NEXT_PUBLIC_SERVER_URL.
CHECKOUT_ALLOWED_ORIGINS=

# ---- Stripe ----
# Powers customer-portal payment methods (M5, embedded Elements) and commerce (M7).
# Use TEST keys (sk_test_… / pk_test_…) in non-prod. Empty = billing stays inert
# (the portal shows a "payments connect at launch" state). Card data is entered on
# Stripe and never stored by CSA. STRIPE_WEBHOOK_SECRET is used by M7 webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: set to "true" to enable Stripe Tax (automatic_tax) on Checkout. Requires
# Stripe Tax to be configured in the Stripe dashboard. Empty/false = no automatic tax.
STRIPE_AUTOMATIC_TAX=

# ---- Safety Chat (M6.5) — Anthropic ----
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_ (it must never reach the browser).
# Empty = Safety Chat stays inert (the assistant replies with a "not configured yet"
# notice; the UI, projects, and chat history still work). Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6).
SAFETY_CHAT_MODEL=claude-sonnet-4-6

# ---- Traefik / runtime ----
APP_DOMAIN=app.example.com
APP_PORT=3000
# Match these to YOUR existing Traefik install (the app attaches via labels). Defaults
# target a Traefik with a shared docker network named `proxy`, a `websecure` (:443)
# entrypoint, and a `letsencrypt` cert resolver. TRAEFIK_ENTRYPOINT_HTTP is only used
# by the optional HTTP->HTTPS redirect router — if your Traefik redirects globally (or
# has no :80 entrypoint), that router is simply ignored. scripts/deploy.sh prompts for these.
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT_HTTP=web
TRAEFIK_ENTRYPOINT_HTTPS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# ---- Seeding (one-time, first deploy) ----
# Credentials for the first Payload /admin user created by `npm run seed:admin`.
# SECURITY: if these are unset the seed falls back to a PUBLICLY-KNOWN default
# (admin@csa.local / ChangeMe!2026) — ALWAYS set a strong SEED_ADMIN_PASSWORD before
# seeding a real deployment, or change it immediately on first login.
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=

# ---- Local override (docker-compose.override.yml) only ----
LOCAL_DB_PASSWORD=postgres
LOCAL_DB_PORT=5432
