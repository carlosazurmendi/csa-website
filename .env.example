# ============================================================================
# CSA — environment template. Copy to `.env` and fill real values.
# Secrets are set in the real environment by the operator — never commit `.env`.
# Only NEXT_PUBLIC_* values are exposed to the browser.
# ============================================================================

# ---- Payload core ----
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32

# ---- Database: EXISTING self-hosted Supabase Postgres ----
# Use the DIRECT/session connection on port 5432 (NOT the 6543 transaction pooler):
# Payload runs DDL + prepared statements that pgBouncer's transaction pooler breaks.
DATABASE_URI=postgres://postgres:PASSWORD@SUPABASE_HOST:5432/postgres
# TLS to self-hosted Supabase:
#   true  (default) -> SSL on; rejectUnauthorized defaults to false (self-signed cert ok)
#   false           -> no SSL (only on a trusted private network / local dev DB)
DATABASE_SSL=true
# Set true once a proper CA chain is trusted by the host.
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ---- Supabase end-user Auth (self-hosted) ----
NEXT_PUBLIC_SUPABASE_URL=https://supabase.your-domain.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...ANON_KEY
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE_KEY

# ---- Media storage: Supabase Storage (S3-compatible) — REQUIRED (no local-disk fallback) ----
# Create a PUBLIC bucket in Supabase Storage, then generate S3 access keys
# (Supabase Studio -> Storage -> Settings -> S3 access keys). Set ALL FOUR S3 vars
# (endpoint, bucket, access key id, secret) together; production refuses to boot
# without them, and a partial set is rejected at startup.
SUPABASE_S3_ENDPOINT=https://supabase.your-domain.com/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=marketing
S3_PROTECTED_BUCKET=course-assets

# ---- Redis (internal compose hostname `redis`, not published) ----
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://default:change-me-strong-redis-password@redis:6379

# ---- Public URLs ----
NEXT_PUBLIC_SERVER_URL=https://app.example.com

# ---- Stripe ----
# Powers customer-portal payment methods (M5, embedded Elements) and commerce (M7).
# Use TEST keys (sk_test_… / pk_test_…) in non-prod. Empty = billing stays inert
# (the portal shows a "payments connect at launch" state). Card data is entered on
# Stripe and never stored by CSA. STRIPE_WEBHOOK_SECRET is used by M7 webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Safety Chat (M6.5) — Anthropic ----
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_ (it must never reach the browser).
# Empty = Safety Chat stays inert (the assistant replies with a "not configured yet"
# notice; the UI, projects, and chat history still work). Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6).
SAFETY_CHAT_MODEL=claude-sonnet-4-6

# ---- Traefik / runtime ----
APP_DOMAIN=app.example.com
APP_PORT=3000

# ---- Local override (docker-compose.override.yml) only ----
LOCAL_DB_PASSWORD=postgres
LOCAL_DB_PORT=5432
