# ----------------------------------------------------------------------------
# CSA Website — environment variables
# Copy to `.env` and fill in. `.env` is gitignored.
# On Vercel, set these in Project → Settings → Environment Variables instead.
# ----------------------------------------------------------------------------

# --- Database (Postgres) ----------------------------------------------------
# Local dev: the Docker Postgres from the README.
# Production: your Supabase Postgres connection string.
#
# In Supabase: Project → "Connect" → use the **Session pooler** URI
# (host aws-0-<region>.pooler.supabase.com, port 5432, user postgres.<ref>).
# Do NOT use the Transaction pooler (port 6543) — it disables the prepared
# statements Payload relies on. Replace [YOUR-PASSWORD] with your DB password.
# Example:
#   postgresql://postgres.abcd1234:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URI=postgresql://csa:csa_dev_pw@localhost:5432/csa

# Secret used to sign Payload auth tokens. Generate for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public site URL (SEO canonical URLs, og tags). Your deployed domain in prod.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Media storage (Supabase Storage, S3-compatible) ------------------------
# Leave BLANK for local-disk uploads (./media) in dev. Set all five to enable
# Supabase Storage (required for Vercel — its filesystem is ephemeral).
#
# Setup in Supabase:
#   1. Storage → create a bucket named "media" → make it PUBLIC.
#   2. Project Settings → Storage → "S3 Connection": copy the Endpoint + Region,
#      then "New access key" to generate the key id + secret.
S3_BUCKET=media
S3_REGION=us-east-1
S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL for served media (the public bucket URL).
NEXT_PUBLIC_S3_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/media
