# ----------------------------------------------------------------------------
# CSA Website — environment variables
# Copy to `.env` and fill in. `.env` is gitignored.
# ----------------------------------------------------------------------------

# Postgres connection string (Payload Postgres adapter).
# Phase 1 dev: local Postgres (see README — `docker run ... postgres:16`).
# Phase 2 / prod: swap to your Supabase Postgres connection string. Nothing
# else changes — the adapter reads this value only.
DATABASE_URI=postgresql://csa:csa_dev_pw@localhost:5432/csa

# Secret used to sign Payload auth tokens. Generate a long random string for
# production: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public site URL (used for SEO canonical URLs, sitemap, og tags).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Media storage (Supabase Storage, S3-compatible endpoint).
# Leave these BLANK in local dev to fall back to local-disk uploads
# (./media). Set all five to enable Supabase Storage (Vercel-safe, the
# Phase 2 target — no adapter change needed later).
# ----------------------------------------------------------------------------
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL for served media (Supabase Storage public URL or CDN).
# Example: https://<project-ref>.supabase.co/storage/v1/object/public/<bucket>
NEXT_PUBLIC_S3_PUBLIC_URL=
