# ============================================================================
# CSA — environment template for the SELF-CONTAINED bundle. Copy to `.env` (or
# paste into dockhand's env editor) and fill the real values. Secrets are set by the
# operator in the real environment — never commit `.env`. Only NEXT_PUBLIC_* values
# reach the browser.
#
# This deployment brings its OWN Postgres + Supabase Auth (GoTrue) + S3 storage
# (MinIO). You only configure the values below; the wiring between services is fixed
# in docker-compose.yml.
#
# DERIVED AUTOMATICALLY in docker-compose.yml — do NOT set these (setting them has no
# effect; they are built from APP_DOMAIN / STORAGE_DOMAIN / POSTGRES_PASSWORD):
#   DATABASE_URI, NEXT_PUBLIC_SUPABASE_URL, SUPABASE_INTERNAL_URL,
#   SUPABASE_S3_ENDPOINT, SUPABASE_S3_PUBLIC_ENDPOINT, NEXT_PUBLIC_SERVER_URL
# ============================================================================

# ---- Payload core ----
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32

# ---- Domain & Traefik ----
# The public site domain (must have a DNS A record at the box) and the storage
# subdomain used for presigned protected downloads/videos (ALSO needs its own A
# record at the same box — Traefik issues its cert automatically).
APP_DOMAIN=csastaging.throughthe.cloud
STORAGE_DOMAIN=files.csastaging.throughthe.cloud
APP_PORT=3000
# Match your Traefik install. The shared network name is hardcoded as the `proxy:`
# external network in docker-compose.yml — change it THERE if yours isn't `proxy`.
TRAEFIK_ENTRYPOINT_HTTP=web
TRAEFIK_ENTRYPOINT_HTTPS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# ---- Image tag (GHCR) ----
# dockhand pulls ghcr.io/<owner>/csa-website[-init]:${IMAGE_TAG}. `latest` follows
# main; pin a `sha-xxxxxxx` (from the build-images workflow) for immutable deploys.
IMAGE_TAG=latest

# ---- Database: bundled Postgres ----
# The `db` service password. DATABASE_URI is built from it automatically
# (postgres://postgres:<this>@db:5432/postgres). Generate: openssl rand -base64 30
POSTGRES_PASSWORD=replace-with-a-strong-db-password
# Same-box private network → TLS off. (DATABASE_SSL/REJECT default false.)
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ---- Supabase Auth keys — GENERATE ALL THREE TOGETHER ----
# Run:  node scripts/gen-supabase-keys.mjs
# It prints GOTRUE_JWT_SECRET + a matching anon JWT + a matching service_role JWT.
# All three MUST come from the same run or auth tokens won't validate.
GOTRUE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: "true" shows the "Continue with Google" button (needs Google OAuth set up
# in GoTrue — the three vars below). Empty/false hides it.
NEXT_PUBLIC_AUTH_GOOGLE=

# ---- Google OAuth (optional "Continue with Google") ----
# In Google Cloud Console → Credentials → OAuth client (Web), add this exact redirect:
#   https://<APP_DOMAIN>/auth/v1/callback
# Then set ENABLED=true + the client id/secret here, and NEXT_PUBLIC_AUTH_GOOGLE=true above.
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# ---- Email confirmation (GoTrue SMTP) ----
# Production requires email confirmation by default (GOTRUE_MAILER_AUTOCONFIRM=false),
# which needs SMTP. Set these to your provider. To launch BEFORE SMTP is ready, set
# GOTRUE_MAILER_AUTOCONFIRM=true temporarily (users confirmed instantly), then revert.
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=no-reply@csastaging.throughthe.cloud
GOTRUE_SMTP_SENDER_NAME=Critical Systems Analysis

# ---- Storage: bundled MinIO (S3-compatible) ----
# MinIO root creds double as the S3 access key/secret the app uses. Generate strong
# values (openssl rand -base64 24). Two buckets are created automatically:
#   marketing      — public-ish (public media is still proxied THROUGH the app)
#   course-assets  — private; reached only via presigned URLs at STORAGE_DOMAIN
MINIO_ROOT_USER=csa-minio
MINIO_ROOT_PASSWORD=replace-with-a-strong-minio-password
SUPABASE_S3_REGION=us-east-1
S3_PUBLIC_BUCKET=marketing
S3_PROTECTED_BUCKET=course-assets

# ---- Redis ----
# Set REDIS_PASSWORD, then embed the SAME password in REDIS_URL.
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://default:replace-with-a-strong-redis-password@redis:6379

# ---- Public URLs ----
# NEXT_PUBLIC_SERVER_URL is derived as https://${APP_DOMAIN}. Extra trusted origins
# (comma-separated) honoured for the checkout/auth redirect — e.g. an apex + www.
CHECKOUT_ALLOWED_ORIGINS=

# ---- Stripe ----
# Use TEST keys in non-prod. Empty = billing inert. STRIPE_WEBHOOK_SECRET is the
# signing secret for the endpoint https://${APP_DOMAIN}/stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# "true" enables Stripe Tax (automatic_tax) on Checkout (requires Stripe Tax set up).
STRIPE_AUTOMATIC_TAX=

# ---- Safety Chat (custom LLM on AWS, OpenAI-compatible, SigV4) ----
# SERVER-ONLY. The assistant is a custom model deployed on AWS, reached through an
# OpenAI /chat/completions endpoint and SigV4-signed with the IAM access key/secret.
# Empty endpoint/creds = Safety Chat replies with a "not configured" notice (UI still works).
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are the IAM creds (also used by storage if shared).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
# Full URL of the OpenAI-compatible chat-completions endpoint (Bedrock OpenAI endpoint,
# a SageMaker/API-Gateway URL fronting the model, etc.).
SAFETY_CHAT_ENDPOINT=
# SigV4 service name for that endpoint: bedrock | sagemaker | execute-api | lambda.
SAFETY_CHAT_AWS_SERVICE=bedrock
# Model id the endpoint expects (leave blank if the endpoint pins a single model).
SAFETY_CHAT_MODEL=

# ---- First admin (Payload /admin login, seeded once on a fresh DB) ----
# If unset, the seed falls back to a PUBLICLY-KNOWN default — always set a strong
# SEED_ADMIN_PASSWORD before the first deploy, or change it immediately on first login.
SEED_ADMIN_EMAIL=admin@csastaging.throughthe.cloud
SEED_ADMIN_PASSWORD=

# ---- Cloudflare cache purge (optional; flushes CDN on every deploy) ----
# /csa/* assets are fixed-name (not hash-busted) and CDN-cached, so shader/CSS/image
# changes don't reach users until the cache is purged. The app purges automatically on
# boot when these are set. Leave empty to disable. Use a SCOPED API token with the
# single permission Zone → Cache Purge for this zone — NOT your global API key.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Optional: comma-separated absolute URLs to purge instead of everything, e.g.
# https://csastaging.throughthe.cloud/csa/vendor/csa-shaders.js,https://csastaging.throughthe.cloud/csa/sys-1-fit.png
CLOUDFLARE_PURGE_FILES=

# ---- Transactional email (order confirmations) ----
# Used by the app (Payload) to email order confirmations after a paid checkout.
# All empty = Payload logs the email instead of sending (orders still fulfil).
# Can point at the SAME SMTP provider as GOTRUE_SMTP_* above.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=no-reply@criticalsystemsanalysis.com
SMTP_FROM_NAME=Critical Systems Analysis
